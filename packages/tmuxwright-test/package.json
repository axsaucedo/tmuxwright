{
  "name": "tmuxwright-test",
  "version": "0.0.0",
  "description": "Standalone Playwright-style test runner for Tmuxwright.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tmuxwright-test": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "tmuxwright": "workspace:*"
  }
}
